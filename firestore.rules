// ===========================================================================
// FANTASIA — Regole di Cloud Firestore
// ===========================================================================
//
// Fantasia NON usa Firestore: la modalità multiplayer gira interamente sul
// Realtime Database. Firestore resta attivo nel progetto solo perché è stato
// creato insieme ad esso.
//
// Con le regole aperte (`allow read, write: if true`) è però un database
// pubblico a tutti gli effetti: chiunque conosca l'identificativo del progetto
// — che è visibile nel codice dell'app, come per ogni chiave web Firebase —
// può scrivere quanti dati vuole, e li paghi tu.
//
// Chiudendolo del tutto non si rompe nulla, perché l'app non lo interroga mai.
//
// Da incollare in Firebase Console → Firestore → Regole, oppure:
//   firebase deploy --only firestore:rules
// ===========================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
